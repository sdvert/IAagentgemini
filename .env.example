# ==============================================
# AGENTE WHATSAPP + GEMINI via Evolution API
# ==============================================
# Copie este arquivo para .env e preencha os valores
# NUNCA suba o .env com valores reais para o Git!

# ----------------------------------------------
# OBRIGATÓRIO — Chave da API Google Gemini
# Obtenha em: https://aistudio.google.com/app/apikey
# ----------------------------------------------
GEMINI_API_KEY=AIzaSy-COLOQUE_SUA_CHAVE_AQUI

# ----------------------------------------------
# OBRIGATÓRIO — Configurações da Evolution API
# ----------------------------------------------

# URL base da sua instância Evolution API
# Exemplo: https://evolution.seudominio.com
EVOLUTION_API_URL=https://evolution.seudominio.com

# Chave global da Evolution API (definida na instalação)
EVOLUTION_API_KEY=SUA_CHAVE_EVOLUTION_AQUI

# Nome da instância WhatsApp criada na Evolution API
EVOLUTION_INSTANCE=minha-instancia

# ----------------------------------------------
# OPCIONAL
# ----------------------------------------------

# Modelo Gemini a usar
# Opções: gemini-2.5-flash | gemini-2.5-flash-lite | gemini-2.5-pro
GEMINI_MODEL=gemini-2.5-flash

# Número do bot (somente dígitos, sem +) — necessário para responder em grupos quando mencionado
# Exemplo: 5511999999999
BOT_NUMBER=

# Secret para validar chamadas do webhook (recomendado)
WEBHOOK_SECRET=

# Caminho do banco SQLite
DB_PATH=/app/data/sessions.db

# Porta do servidor HTTP
PORT=3000

# ----------------------------------------------
# OPCIONAL — Integração ClickUp
# CLICKUP_API_KEY: Configurações → Apps → API Token
# CLICKUP_TEAM_ID: ID do workspace (aparece na URL do ClickUp)
# ----------------------------------------------
CLICKUP_API_KEY=pk_COLOQUE_SEU_TOKEN_AQUI
CLICKUP_TEAM_ID=SEU_TEAM_ID_AQUI

# ----------------------------------------------
# OPCIONAL — Modelos de mídia Gemini
# ----------------------------------------------
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
